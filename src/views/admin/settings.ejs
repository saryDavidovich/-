<%- include('partials/header', { pageTitle: 'הגדרות - ' + list.name, page: 'settings', activeListId: list.id, allLists: allLists }) %>

  <%- include('partials/tabbar', { list, page: 'settings' }) %>

  <div class="card" style="max-width:520px;">
    <form method="POST" action="/admin/lists/<%= list.id %>/settings">

      <label>שם הרשימה</label>
      <input type="text" name="name" value="<%= list.name %>" required />

      <label>תיאור פנימי</label>
      <input type="text" name="description" value="<%= list.description || '' %>" />

      <label>צבע הדגשה</label>
      <input type="color" name="accent_color" value="<%= list.accent_color %>" style="height:40px;padding:2px;" />

      <div class="sidebar-divider" style="background:#e3e1d8;margin:16px 0;"></div>

      <div class="pill" style="display:block;margin-bottom:12px;line-height:1.6;">
        סדר הפריטים בגיליון (שאלות/מודעות/נושאים, בכל שילוב) נקבע כעת בגרירה חופשית בתצוגה המקדימה שבצד - לא כאן.
      </div>

      <div class="sidebar-divider" style="background:#e3e1d8;margin:16px 0;"></div>

      <label style="display:flex;align-items:center;gap:8px;">
        <input type="checkbox" name="show_ask_button" value="1" <%= list.show_ask_button ? 'checked' : '' %> style="width:auto;margin:0;" />
        הצג כפתור "לשליחת שאלה חדשה" בתוך הגיליון
      </label>
      <label style="display:flex;align-items:center;gap:8px;margin-top:8px;">
        <input type="checkbox" name="show_ad_buttons" value="1" <%= list.show_ad_buttons ? 'checked' : '' %> style="width:auto;margin:0;" />
        הצג כפתורי "פרסום מודעה" (חינם / מודגשת / פרימיום) בתוך הגיליון
      </label>

      <button class="btn" type="submit" style="margin-top:16px;">שמור הגדרות</button>
    </form>
  </div>

<%- include('partials/footer') %>
